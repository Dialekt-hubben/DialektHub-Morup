{
    "name": "dialekthub-nextjs",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "docker compose up -d db && docker compose up -d S3Ninja && next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "format": "prettier --write .",
        "db:studio": "drizzle-kit studio --config ./drizzle.config.ts",
        "db:migrate": "drizzle-kit migrate --config ./drizzle.config.ts",
        "db:generate": "drizzle-kit generate --config ./drizzle.config.ts",
        "db:seed": "tsx src/Drizzle/seed.ts",
        "db:reset": "docker compose down -v && docker compose up -d --build && npm run db:migrate && npm run db:seed && docker compose down"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1000.0",
        "@aws-sdk/s3-request-presigner": "^3.1000.0",
        "@hookform/resolvers": "^5.2.2",
        "@libsql/client": "^0.17.0",
        "@t3-oss/env-nextjs": "^0.13.10",
        "better-auth": "^1.4.20",
        "dotenv": "^17.3.1",
        "drizzle-orm": "^0.45.2",
        "mysql2": "^3.21.1",
        "next": "^16.1.6",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-hook-form": "^7.70.0",
        "xlsx": "^0.18.5",
        "zod": "^4.3.5"
    },
    "devDependencies": {
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "drizzle-kit": "^0.31.10",
        "eslint": "^9",
        "eslint-config-next": "^16.1.6",
        "prettier": "3.8.1",
        "tsx": "^4.21.0",
        "typescript": "^5"
    }
}
